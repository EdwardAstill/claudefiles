#!/usr/bin/env bash
# cf-status — generates a full branch/worktree topology map for the current repo
#
# Usage:
#   cf-status           # print to stdout
#   cf-status --write   # also write to .claudefiles/repo-map.md

set -euo pipefail

CF_LIB="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)/../lib"
source "$CF_LIB/common.sh"

WRITE=false
for arg in "$@"; do [[ "$arg" == "--write" ]] && WRITE=true; done

cf_require_git
GIT_ROOT="$(cf_git_root)"

OUT=""
line() { OUT+="$*"$'\n'; }
blank() { OUT+=$'\n'; }

# Find trunk branch (main, master, or current default)
find_trunk() {
    if git show-ref --verify --quiet refs/heads/main; then
        echo "main"
    elif git show-ref --verify --quiet refs/heads/master; then
        echo "master"
    else
        git symbolic-ref --short HEAD 2>/dev/null || echo "HEAD"
    fi
}

TRUNK="$(find_trunk)"

declare -A WORKTREE_PATH
declare -A WORKTREE_PORT

parse_worktrees() {
    local path="" branch="" bare=""
    while IFS= read -r l; do
        if [[ "$l" == worktree\ * ]]; then
            path="${l#worktree }"
        elif [[ "$l" == branch\ * ]]; then
            branch="${l#branch refs/heads/}"
        elif [[ "$l" == "bare" ]]; then
            bare=1
        elif [[ -z "$l" && -n "$path" && -n "$branch" ]]; then
            WORKTREE_PATH["$branch"]="$path"
            if [[ -f "$path/.env" ]]; then
                local port
                port="$(grep -m1 '^PORT=' "$path/.env" 2>/dev/null | cut -d= -f2 || true)"
                [[ -n "$port" ]] && WORKTREE_PORT["$branch"]="$port"
            fi
            path=""; branch=""; bare=""
        fi
    done < <(git worktree list --porcelain)
}

parse_worktrees

NOW="$(date '+%Y-%m-%d %H:%M:%S')"
line "# REPO MAP"
line "# Generated: $NOW"
line "# Repo:      $GIT_ROOT"
blank

TRUNK_HEAD="$(git rev-parse --short "$TRUNK" 2>/dev/null || echo "unknown")"
TRUNK_MSG="$(git log -1 --pretty=format:'%s' "$TRUNK" 2>/dev/null || echo "")"
TRUNK_PATH="${WORKTREE_PATH[$TRUNK]:-$GIT_ROOT}"
TRUNK_REMOTE="$(git for-each-ref --format='%(upstream:short)' "refs/heads/$TRUNK" 2>/dev/null || true)"

if [[ -n "$TRUNK_REMOTE" ]]; then
    BEHIND="$(git rev-list --count "$TRUNK".."$TRUNK_REMOTE" 2>/dev/null || echo 0)"
    AHEAD="$(git rev-list --count "$TRUNK_REMOTE".."$TRUNK" 2>/dev/null || echo 0)"
    if [[ "$AHEAD" == "0" && "$BEHIND" == "0" ]]; then SYNC="(in sync)"
    elif [[ "$AHEAD" != "0" && "$BEHIND" == "0" ]]; then SYNC="($AHEAD ahead — not yet pushed)"
    elif [[ "$AHEAD" == "0" && "$BEHIND" != "0" ]]; then SYNC="($BEHIND behind — pull available)"
    else SYNC="(diverged: +$AHEAD / -$BEHIND)"
    fi
else
    SYNC="(no remote tracking)"
fi

line "TRUNK"
line "  branch:  $TRUNK"
line "  HEAD:    $TRUNK_HEAD  \"$TRUNK_MSG\""
line "  remote:  ${TRUNK_REMOTE:-none} $SYNC"
line "  path:    $TRUNK_PATH"
blank

ALL_BRANCHES="$(git branch --format='%(refname:short)' | grep -v "^$TRUNK$" || true)"
WARNINGS=()
STALE=()
ACTIVE_BRANCHES=0
ACTIVE_WORKTREES=0
DIVERGED=0

if [[ -n "$ALL_BRANCHES" ]]; then
    line "BRANCHES & WORKTREES ──────────────────────────────────────────────"
    blank

    while IFS= read -r branch; do
        [[ -z "$branch" ]] && continue

        git rev-parse --short "$branch" &>/dev/null || continue

        MERGE_BASE="$(git merge-base "$TRUNK" "$branch" 2>/dev/null || echo "")"
        if [[ -n "$MERGE_BASE" ]]; then
            BASE_HASH="$(git rev-parse --short "$MERGE_BASE")"
            BASE_MSG="$(git log -1 --pretty=format:'%s' "$MERGE_BASE")"
            BASE_AGO="$(git log -1 --pretty=format:'%cr' "$MERGE_BASE")"
        else
            BASE_HASH="unknown"; BASE_MSG="unknown"; BASE_AGO=""
        fi

        AHEAD_COUNT="$(git rev-list --count "$TRUNK".."$branch" 2>/dev/null || echo 0)"
        BEHIND_COUNT="$(git rev-list --count "$branch".."$TRUNK" 2>/dev/null || echo 0)"

        if [[ "$AHEAD_COUNT" == "0" ]]; then
            STALE+=("$branch")
            continue
        fi

        ACTIVE_BRANCHES=$((ACTIVE_BRANCHES + 1))
        WT_PATH="${WORKTREE_PATH[$branch]:-}"
        WT_PORT="${WORKTREE_PORT[$branch]:-}"
        STATUS_LABEL="CLEAN"

        if [[ -n "$WT_PATH" && -d "$WT_PATH" ]]; then
            ACTIVE_WORKTREES=$((ACTIVE_WORKTREES + 1))
            DIRTY="$(git -C "$WT_PATH" status --short 2>/dev/null || true)"
            if [[ -n "$DIRTY" ]]; then
                MOD="$(echo "$DIRTY" | grep -c '^ M\|^M ' || true)"
                UNTRACK="$(echo "$DIRTY" | grep -c '^??' || true)"
                STATUS_LABEL="DIRTY (${MOD} modified, ${UNTRACK} untracked)"
            fi
        fi

        COMMITS="$(git log --oneline "$MERGE_BASE".."$branch" 2>/dev/null | head -5 || true)"
        DIFF_STAT="$(git diff --stat "$TRUNK"..."$branch" 2>/dev/null | tail -1 | sed 's/^ *//' || true)"

        line "$branch"
        if [[ -n "$WT_PATH" ]]; then
            line "  worktree:    $WT_PATH"
            [[ -n "$WT_PORT" ]] && line "  port:        $WT_PORT"
        else
            line "  worktree:    none (local branch)"
        fi
        line "  status:      $STATUS_LABEL"
        line "  branched from: $BASE_HASH  \"$BASE_MSG\"  [$BASE_AGO]"

        if [[ -n "$COMMITS" ]]; then
            line "  commits since branch:"
            local_i=0
            while IFS= read -r commit_line; do
                if [[ $local_i == 0 ]]; then line "    HEAD     $commit_line"
                else line "    HEAD~$local_i   $commit_line"
                fi
                local_i=$((local_i + 1))
            done <<< "$COMMITS"
        fi

        if [[ "$BEHIND_COUNT" -gt 0 ]]; then
            line "  ahead/behind $TRUNK:  +$AHEAD_COUNT / $BEHIND_COUNT   ← BEHIND: $TRUNK has moved, consider rebasing"
            WARNINGS+=("! $branch is $BEHIND_COUNT commit(s) behind $TRUNK — consider: git rebase $TRUNK")
            DIVERGED=$((DIVERGED + 1))
        else
            line "  ahead/behind $TRUNK:  +$AHEAD_COUNT / 0"
        fi

        [[ -n "$DIFF_STAT" ]] && line "  diff summary:  $DIFF_STAT"
        blank

    done <<< "$ALL_BRANCHES"
fi

if [[ ${#STALE[@]} -gt 0 ]]; then
    line "STALE / MERGED ────────────────────────────────────────────────────"
    blank
    for branch in "${STALE[@]}"; do
        LAST_AGO="$(git log -1 --pretty=format:'%cr' "$branch" 2>/dev/null || echo "unknown")"
        line "$branch"
        line "  status:      fully merged into $TRUNK"
        line "  last commit: $LAST_AGO"
        line "  suggestion:  safe to delete → git branch -d $branch"
        blank
    done
fi

if [[ ${#WARNINGS[@]} -gt 0 ]]; then
    line "DIVERGENCE WARNINGS ───────────────────────────────────────────────"
    blank
    for w in "${WARNINGS[@]}"; do line "$w"; done
    blank
fi

STALE_COUNT="${#STALE[@]}"
line "SNAPSHOT ──────────────────────────────────────────────────────────"
blank
line "  $ACTIVE_BRANCHES active branch(es)  |  $ACTIVE_WORKTREES worktree(s)  |  $STALE_COUNT stale  |  $DIVERGED diverged"
blank

printf '%s' "$OUT"

if "$WRITE"; then
    BUS="$(cf_ensure_bus)"
    printf '%s' "$OUT" > "$BUS/repo-map.md"
    echo "# Written to $BUS/repo-map.md" >&2
fi
