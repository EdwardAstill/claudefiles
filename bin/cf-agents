#!/usr/bin/env bash
# cf-agents — overview of all Claude Code skills and MCP servers across every scope
#
# Usage:
#   cf-agents              # full overview
#   cf-agents --global     # global scope only (plugins, user skills, global MCP)
#   cf-agents --project    # project scope only (project skills, project MCP)
#   cf-agents --mcp        # MCP servers only (global + project)
#   cf-agents --available  # what's in claudefiles but not installed

set -euo pipefail

CF_LIB="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)/../lib"
CF_BIN="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
CLAUDEFILES_ROOT="$(cd "$CF_BIN/.." && pwd)"
source "$CF_LIB/common.sh"

SHOW_GLOBAL=true
SHOW_PROJECT=true
SHOW_MCP=true
SHOW_AVAILABLE=true

for arg in "$@"; do
    case "$arg" in
        --global)    SHOW_PROJECT=false; SHOW_AVAILABLE=false; SHOW_MCP=true ;;
        --project)   SHOW_GLOBAL=false;  SHOW_AVAILABLE=false; SHOW_MCP=true ;;
        --mcp)       SHOW_GLOBAL=false;  SHOW_PROJECT=false; SHOW_AVAILABLE=false; SHOW_MCP=true ;;
        --available) SHOW_GLOBAL=false;  SHOW_PROJECT=false; SHOW_MCP=false ;;
    esac
done

DIVIDER="$(printf '%0.s─' {1..60})"

# ── Helpers ───────────────────────────────────────────────────────────────────

skill_name() {
    awk '/^name:/ { gsub(/^name: */, ""); print; exit }' "$1" 2>/dev/null || basename "$(dirname "$1")"
}

skill_desc() {
    awk '/^description:/{found=1; next} found && /^  /{gsub(/^  /, ""); print; exit} found && /^[^ ]/{exit}' "$1" 2>/dev/null | head -1
}

# Print MCP servers from a .mcp.json file
print_mcp_file() {
    local file="$1"
    local scope="$2"   # "global" or "project"

    [[ ! -f "$file" ]] && echo "  (no .mcp.json found)" && return

    python3 - "$file" "$scope" <<'PYEOF'
import json, sys, os

mcp_file = sys.argv[1]
scope = sys.argv[2]

try:
    with open(mcp_file) as f:
        data = json.load(f)
except Exception as e:
    print(f"  (error reading {mcp_file}: {e})")
    sys.exit(0)

servers = data.get("mcpServers", {})
if not servers:
    print("  (no servers configured)")
    sys.exit(0)

for name, config in servers.items():
    # Determine transport
    if "url" in config:
        transport = "sse"
        target = config["url"]
    elif "command" in config:
        transport = "stdio"
        args = config.get("args", [])
        target = config["command"] + (" " + " ".join(str(a) for a in args) if args else "")
    else:
        transport = "unknown"
        target = str(config)

    print(f"  • {name}  [{transport}]")
    print(f"    {target[:100]}{'...' if len(target) > 100 else ''}")

    # Show env vars (keys only, not values — they may be secrets)
    env = config.get("env", {})
    if env:
        print(f"    env: {', '.join(env.keys())}")
PYEOF
}

# ── Global: Plugins ───────────────────────────────────────────────────────────

if "$SHOW_GLOBAL"; then
    echo ""
    echo "GLOBAL — PLUGINS"
    echo "$DIVIDER"

    PLUGINS_JSON="$HOME/.claude/plugins/installed_plugins.json"
    SETTINGS_JSON="$HOME/.claude/settings.json"

    if [[ -f "$PLUGINS_JSON" ]]; then
        python3 - "$PLUGINS_JSON" "$SETTINGS_JSON" <<'PYEOF'
import json, sys, os

plugins_file = sys.argv[1]
settings_file = sys.argv[2] if len(sys.argv) > 2 else None

with open(plugins_file) as f:
    plugins = json.load(f)

enabled = set()
if settings_file and os.path.exists(settings_file):
    with open(settings_file) as f:
        settings = json.load(f)
    enabled = {k for k, v in settings.get("enabledPlugins", {}).items() if v}

for plugin_key, installs in plugins.items():
    if not installs:
        continue
    install = installs[0]
    path = install.get("installPath", "")
    version = install.get("version", "?")
    plugin_name = plugin_key.split("@")[0]
    status = "enabled" if plugin_key in enabled else "disabled"

    print(f"\n  {plugin_name}  (v{version})  [{status}]")

    skills_dir = os.path.join(path, "skills")
    if os.path.isdir(skills_dir):
        for root, dirs, files in os.walk(skills_dir):
            for f in sorted(files):
                if f == "SKILL.md":
                    skill_path = os.path.join(root, f)
                    name = None
                    desc = None
                    in_desc = False
                    with open(skill_path) as sf:
                        for line in sf:
                            line = line.rstrip()
                            if line.startswith("name:"):
                                name = line.split(":", 1)[1].strip()
                            elif line.startswith("description:"):
                                in_desc = True
                            elif in_desc and line.startswith("  "):
                                desc = line.strip()
                                break
                            elif in_desc:
                                break
                    if name:
                        print(f"    • {name}")
                        if desc:
                            print(f"      {desc[:80]}{'...' if len(desc) > 80 else ''}")
PYEOF
    else
        echo "  (installed_plugins.json not found)"
    fi

    echo ""
    echo "GLOBAL — USER SKILLS  (~/.claude/skills/)"
    echo "$DIVIDER"

    USER_SKILLS="$HOME/.claude/skills"
    if [[ -d "$USER_SKILLS" ]]; then
        found_any=false
        while IFS= read -r skill_md; do
            name="$(skill_name "$skill_md")"
            desc="$(skill_desc "$skill_md")"
            echo "  • $name"
            [[ -n "$desc" ]] && echo "    $desc"
            found_any=true
        done < <(find "$USER_SKILLS" -name "SKILL.md" | sort)
        "$found_any" || echo "  (none)"
    else
        echo "  (directory does not exist)"
    fi
fi

# ── MCP Servers ───────────────────────────────────────────────────────────────

if "$SHOW_MCP"; then
    echo ""

    # .mcp.json may not be at ~/.claude/.mcp.json if ~/.claude is a symlink to
    # session data (as in a stow-based dotfiles setup). Check multiple locations.
    GLOBAL_MCP=""
    for candidate in \
        "$HOME/.claude/.mcp.json" \
        "${DOTFILES:-}/app-configuration/claude/.claude/.mcp.json" \
        "$HOME/dotfiles/app-configuration/claude/.claude/.mcp.json"
    do
        [[ -f "$candidate" ]] && GLOBAL_MCP="$candidate" && break
    done

    echo "GLOBAL — MCP SERVERS  (${GLOBAL_MCP:-not found})"
    echo "$DIVIDER"
    if [[ -n "$GLOBAL_MCP" ]]; then
        print_mcp_file "$GLOBAL_MCP" "global"
    else
        echo "  (no global .mcp.json found)"
        echo "  Expected: ~/.claude/.mcp.json"
    fi

    GIT_ROOT="$(cf_git_root 2>/dev/null || echo "")"
    if [[ -n "$GIT_ROOT" ]]; then
        echo ""
        echo "PROJECT — MCP SERVERS  (.mcp.json)"
        echo "$DIVIDER"
        if [[ -f "$GIT_ROOT/.mcp.json" ]]; then
            print_mcp_file "$GIT_ROOT/.mcp.json" "project"
        else
            echo "  (no .mcp.json in project root)"
            echo "  Create .mcp.json to add project-specific MCP servers"
        fi
    fi
fi

# ── Project Skills ────────────────────────────────────────────────────────────

if "$SHOW_PROJECT"; then
    echo ""

    GIT_ROOT="$(cf_git_root 2>/dev/null || echo "")"
    if [[ -n "$GIT_ROOT" ]]; then
        PROJECT_SKILLS="$GIT_ROOT/.claude/skills"
        echo "PROJECT — SKILLS  $(basename "$GIT_ROOT")/.claude/skills/"
        echo "$DIVIDER"
        if [[ -d "$PROJECT_SKILLS" ]]; then
            found_any=false
            while IFS= read -r skill_md; do
                name="$(skill_name "$skill_md")"
                desc="$(skill_desc "$skill_md")"
                echo "  • $name"
                [[ -n "$desc" ]] && echo "    $desc"
                found_any=true
            done < <(find "$PROJECT_SKILLS" -name "SKILL.md" | sort)
            "$found_any" || echo "  (none)"
        else
            echo "  (no project-level skills installed)"
            echo "  Install with: cd $CLAUDEFILES_ROOT && ./install.sh --project $GIT_ROOT"
        fi
    else
        echo "PROJECT — SKILLS"
        echo "$DIVIDER"
        echo "  (not inside a git repository)"
    fi
fi

# ── Available in claudefiles but not installed ────────────────────────────────

if "$SHOW_AVAILABLE"; then
    echo ""
    echo "AVAILABLE IN CLAUDEFILES  (not yet installed)"
    echo "$DIVIDER"

    DEV_SUITE="$CLAUDEFILES_ROOT/dev-suite"
    USER_SKILLS="$HOME/.claude/skills"

    found_any=false
    while IFS= read -r skill_md; do
        name="$(skill_name "$skill_md")"
        desc="$(skill_desc "$skill_md")"

        if find "$USER_SKILLS" -name "SKILL.md" 2>/dev/null | xargs grep -l "^name: $name$" &>/dev/null; then
            continue
        fi

        echo "  • $name  [not installed]"
        [[ -n "$desc" ]] && echo "    $desc"
        found_any=true
    done < <(find "$DEV_SUITE" -name "SKILL.md" | sort)

    "$found_any" || echo "  (all claudefiles skills are installed)"
    echo ""
    echo "  Install all: cd $CLAUDEFILES_ROOT && ./install.sh --user"
fi

echo ""
