#!/usr/bin/env bash
# cf-agents — overview of all Claude Code skills and MCP servers across every scope
#
# Usage:
#   cf-agents              # full overview
#   cf-agents --global     # global scope only (plugins, user skills, global MCP)
#   cf-agents --project    # project scope only (project skills, project MCP)
#   cf-agents --mcp        # MCP servers only (global + project)
#   cf-agents --available  # what's in claudefiles but not installed

set -euo pipefail

CF_LIB="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)/../lib"
CF_BIN="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
CLAUDEFILES_ROOT="$(cd "$CF_BIN/.." && pwd)"
source "$CF_LIB/common.sh"

SHOW_GLOBAL=true
SHOW_PROJECT=true
SHOW_MCP=true
SHOW_AVAILABLE=true
TREE_ONLY=false

for arg in "$@"; do
    case "$arg" in
        --global)    SHOW_PROJECT=false; SHOW_AVAILABLE=false; SHOW_MCP=true ;;
        --project)   SHOW_GLOBAL=false;  SHOW_AVAILABLE=false; SHOW_MCP=true ;;
        --mcp)       SHOW_GLOBAL=false;  SHOW_PROJECT=false; SHOW_AVAILABLE=false; SHOW_MCP=true ;;
        --available) SHOW_GLOBAL=false;  SHOW_PROJECT=false; SHOW_MCP=false ;;
        --tree)      TREE_ONLY=true ;;
    esac
done

DIVIDER="$(printf '%0.s─' {1..60})"

# ── Helpers ───────────────────────────────────────────────────────────────────

skill_name() {
    awk '/^name:/ { gsub(/^name: */, ""); print; exit }' "$1" 2>/dev/null || basename "$(dirname "$1")"
}

skill_desc() {
    awk '/^description:/{found=1; next} found && /^  /{gsub(/^  /, ""); print; exit} found && /^[^ ]/{exit}' "$1" 2>/dev/null | head -1
}

# Render a skills directory as a tree, respecting category hierarchy
render_tree() {
    local dir="$1"
    local prefix="${2:-}"
    local entries=()

    # Collect immediate children (dirs only)
    while IFS= read -r entry; do
        entries+=("$entry")
    done < <(find "$dir" -mindepth 1 -maxdepth 1 -type d | sort)

    local count="${#entries[@]}"
    local i=0

    for entry in "${entries[@]}"; do
        i=$((i + 1))
        local name
        name="$(basename "$entry")"
        local is_last=false
        [[ $i -eq $count ]] && is_last=true

        local connector="├──"
        local child_prefix="│   "
        "$is_last" && connector="└──" && child_prefix="    "

        if [[ -f "$entry/SKILL.md" ]]; then
            local skill
            skill="$(skill_name "$entry/SKILL.md")"
            # Check if this is a category (has subdirs with SKILL.md) or leaf
            local subdirs
            subdirs="$(find "$entry" -mindepth 2 -name "SKILL.md" 2>/dev/null | wc -l)"
            if [[ "$subdirs" -gt 0 ]]; then
                echo "${prefix}${connector} ${name}/  [category: ${skill}]"
                render_tree "$entry" "${prefix}${child_prefix}"
            else
                echo "${prefix}${connector} ${skill}"
            fi
        else
            # Directory without SKILL.md — show as group
            echo "${prefix}${connector} ${name}/"
            render_tree "$entry" "${prefix}${child_prefix}"
        fi
    done
}

# Show tree for a given skills root dir
print_tree() {
    local root="$1"
    local label="$2"
    echo "$label"
    # Each top-level entry in the skills dir
    local entries=()
    while IFS= read -r entry; do
        entries+=("$entry")
    done < <(find "$root" -mindepth 1 -maxdepth 1 -type d | sort)

    local count="${#entries[@]}"
    local i=0
    for entry in "${entries[@]}"; do
        i=$((i + 1))
        local name
        name="$(basename "$entry")"
        local is_last=false
        [[ $i -eq $count ]] && is_last=true
        local connector="├──"
        local child_prefix="│   "
        "$is_last" && connector="└──" && child_prefix="    "

        if [[ -f "$entry/SKILL.md" ]]; then
            local subdirs
            subdirs="$(find "$entry" -mindepth 2 -name "SKILL.md" 2>/dev/null | wc -l)"
            if [[ "$subdirs" -gt 0 ]]; then
                local skill
                skill="$(skill_name "$entry/SKILL.md")"
                echo "${connector} ${name}/  [${skill}]"
                render_tree "$entry" "${child_prefix}"
            else
                echo "${connector} $(skill_name "$entry/SKILL.md")"
            fi
        else
            echo "${connector} ${name}/"
            render_tree "$entry" "${child_prefix}"
        fi
    done
}

# Print MCP servers from a .mcp.json file
print_mcp_file() {
    local file="$1"
    local scope="$2"   # "global" or "project"

    [[ ! -f "$file" ]] && echo "  (no .mcp.json found)" && return

    python3 - "$file" "$scope" <<'PYEOF'
import json, sys, os

mcp_file = sys.argv[1]
scope = sys.argv[2]

try:
    with open(mcp_file) as f:
        data = json.load(f)
except Exception as e:
    print(f"  (error reading {mcp_file}: {e})")
    sys.exit(0)

servers = data.get("mcpServers", {})
if not servers:
    print("  (no servers configured)")
    sys.exit(0)

for name, config in servers.items():
    # Determine transport
    if "url" in config:
        transport = "sse"
        target = config["url"]
    elif "command" in config:
        transport = "stdio"
        args = config.get("args", [])
        target = config["command"] + (" " + " ".join(str(a) for a in args) if args else "")
    else:
        transport = "unknown"
        target = str(config)

    print(f"  • {name}  [{transport}]")
    print(f"    {target[:100]}{'...' if len(target) > 100 else ''}")

    # Show env vars (keys only, not values — they may be secrets)
    env = config.get("env", {})
    if env:
        print(f"    env: {', '.join(env.keys())}")
PYEOF
}

# ── Global: Plugins ───────────────────────────────────────────────────────────

if "$SHOW_GLOBAL"; then
    echo ""
    echo "GLOBAL — PLUGINS"
    echo "$DIVIDER"

    PLUGINS_JSON="$HOME/.claude/plugins/installed_plugins.json"
    SETTINGS_JSON="$HOME/.claude/settings.json"

    if [[ -f "$PLUGINS_JSON" ]]; then
        python3 - "$PLUGINS_JSON" "$SETTINGS_JSON" <<'PYEOF'
import json, sys, os

plugins_file = sys.argv[1]
settings_file = sys.argv[2] if len(sys.argv) > 2 else None

with open(plugins_file) as f:
    plugins = json.load(f)

enabled = set()
if settings_file and os.path.exists(settings_file):
    with open(settings_file) as f:
        settings = json.load(f)
    enabled = {k for k, v in settings.get("enabledPlugins", {}).items() if v}

for plugin_key, installs in plugins.items():
    if not installs:
        continue
    install = installs[0]
    path = install.get("installPath", "")
    version = install.get("version", "?")
    plugin_name = plugin_key.split("@")[0]
    status = "enabled" if plugin_key in enabled else "disabled"

    print(f"\n  {plugin_name}  (v{version})  [{status}]")

    skills_dir = os.path.join(path, "skills")
    if os.path.isdir(skills_dir):
        for root, dirs, files in os.walk(skills_dir):
            for f in sorted(files):
                if f == "SKILL.md":
                    skill_path = os.path.join(root, f)
                    name = None
                    desc = None
                    in_desc = False
                    with open(skill_path) as sf:
                        for line in sf:
                            line = line.rstrip()
                            if line.startswith("name:"):
                                name = line.split(":", 1)[1].strip()
                            elif line.startswith("description:"):
                                in_desc = True
                            elif in_desc and line.startswith("  "):
                                desc = line.strip()
                                break
                            elif in_desc:
                                break
                    if name:
                        print(f"    • {name}")
                        if desc:
                            print(f"      {desc[:80]}{'...' if len(desc) > 80 else ''}")
PYEOF
    else
        echo "  (installed_plugins.json not found)"
    fi

    echo ""
    echo "GLOBAL — USER SKILLS  (~/.claude/skills/)"
    echo "$DIVIDER"

    USER_SKILLS="$HOME/.claude/skills"
    if [[ -d "$USER_SKILLS" ]]; then
        print_tree "$USER_SKILLS" ""
    else
        echo "  (directory does not exist)"
    fi
fi

# ── Tree-only mode ────────────────────────────────────────────────────────────

if "$TREE_ONLY"; then
    echo ""
    echo "SKILL TREE"
    echo "$DIVIDER"
    print_tree "$CLAUDEFILES_ROOT/dev-suite" "dev-suite/"
    echo ""
    exit 0
fi

# ── MCP Servers ───────────────────────────────────────────────────────────────

if "$SHOW_MCP"; then
    echo ""

    # .mcp.json may not be at ~/.claude/.mcp.json if ~/.claude is a symlink to
    # session data (as in a stow-based dotfiles setup). Check multiple locations.
    GLOBAL_MCP=""
    for candidate in \
        "$HOME/.claude/.mcp.json" \
        "${DOTFILES:-}/app-configuration/claude/.claude/.mcp.json" \
        "$HOME/dotfiles/app-configuration/claude/.claude/.mcp.json"
    do
        [[ -f "$candidate" ]] && GLOBAL_MCP="$candidate" && break
    done

    echo "GLOBAL — MCP SERVERS  (${GLOBAL_MCP:-not found})"
    echo "$DIVIDER"
    if [[ -n "$GLOBAL_MCP" ]]; then
        print_mcp_file "$GLOBAL_MCP" "global"
    else
        echo "  (no global .mcp.json found)"
        echo "  Expected: ~/.claude/.mcp.json"
    fi

    GIT_ROOT="$(cf_git_root 2>/dev/null || echo "")"
    if [[ -n "$GIT_ROOT" ]]; then
        echo ""
        echo "PROJECT — MCP SERVERS  (.mcp.json)"
        echo "$DIVIDER"
        if [[ -f "$GIT_ROOT/.mcp.json" ]]; then
            print_mcp_file "$GIT_ROOT/.mcp.json" "project"
        else
            echo "  (no .mcp.json in project root)"
            echo "  Create .mcp.json to add project-specific MCP servers"
        fi
    fi
fi

# ── Project Skills ────────────────────────────────────────────────────────────

if "$SHOW_PROJECT"; then
    echo ""

    GIT_ROOT="$(cf_git_root 2>/dev/null || echo "")"
    if [[ -n "$GIT_ROOT" ]]; then
        PROJECT_SKILLS="$GIT_ROOT/.claude/skills"
        echo "PROJECT — SKILLS  $(basename "$GIT_ROOT")/.claude/skills/"
        echo "$DIVIDER"
        if [[ -d "$PROJECT_SKILLS" ]]; then
            print_tree "$PROJECT_SKILLS" ""
        else
            echo "  (no project-level skills installed)"
            echo "  Install with: cd $CLAUDEFILES_ROOT && ./install.sh --project $GIT_ROOT"
        fi
    else
        echo "PROJECT — SKILLS"
        echo "$DIVIDER"
        echo "  (not inside a git repository)"
    fi
fi

# ── Available in claudefiles but not installed ────────────────────────────────

if "$SHOW_AVAILABLE"; then
    echo ""
    echo "AVAILABLE IN CLAUDEFILES  (not yet installed)"
    echo "$DIVIDER"

    DEV_SUITE="$CLAUDEFILES_ROOT/dev-suite"
    USER_SKILLS="$HOME/.claude/skills"

    found_any=false
    while IFS= read -r skill_md; do
        name="$(skill_name "$skill_md")"
        desc="$(skill_desc "$skill_md")"

        if find "$USER_SKILLS" -name "SKILL.md" 2>/dev/null | xargs grep -l "^name: $name$" &>/dev/null; then
            continue
        fi

        echo "  • $name  [not installed]"
        [[ -n "$desc" ]] && echo "    $desc"
        found_any=true
    done < <(find "$DEV_SUITE" -name "SKILL.md" | sort)

    "$found_any" || echo "  (all claudefiles skills are installed)"
    echo ""
    echo "  Install all: cd $CLAUDEFILES_ROOT && ./install.sh --user"
fi

# ── CLI Tool Dependencies ─────────────────────────────────────────────────────

echo ""
echo "CLI TOOL DEPENDENCIES"
echo "$DIVIDER"

MANIFEST="$CLAUDEFILES_ROOT/manifest.toml"

python3 - "$MANIFEST" <<'PYEOF'
import sys, subprocess, shutil

manifest_file = sys.argv[1]

# Parse manifest.toml for [cli.*] entries
cli_tools = {}
current_tool = None
try:
    with open(manifest_file) as f:
        for line in f:
            line = line.rstrip()
            if line.startswith("[cli."):
                current_tool = line[5:].rstrip("]").strip()
                cli_tools[current_tool] = {}
            elif current_tool and "=" in line and not line.startswith("["):
                key, _, val = line.partition("=")
                cli_tools[current_tool][key.strip()] = val.strip().strip('"')
except Exception as e:
    print(f"  (error reading manifest: {e})")
    sys.exit(0)

if not cli_tools:
    print("  (no CLI tool dependencies declared in manifest.toml)")
    sys.exit(0)

# Check package managers first
manager_installs = {
    "bun":    "curl -fsSL https://bun.sh/install | bash",
    "uv":     "curl -LsSf https://astral.sh/uv/install.sh | sh",
    "cargo":  "curl https://sh.rustup.rs -sSf | sh",
    "rustup": "curl https://sh.rustup.rs -sSf | sh",
}
managers = {m: shutil.which(m) for m in manager_installs}

missing_managers = [m for m, p in managers.items() if p is None]
# Only warn about managers actually used by a declared tool
used_managers = {info.get("manager") for info in cli_tools.values()}
missing_used = [m for m in missing_managers if m in used_managers]
if missing_used:
    print()
    for mgr in missing_used:
        print(f"  ⚠  {mgr} not found — required for some CLI tools")
        print(f"     Install: {manager_installs[mgr]}")
    print()

# Check each CLI tool
for name, info in cli_tools.items():
    mgr = info.get("manager", "?")
    pkg = info.get("package", name)
    desc = info.get("description", "")
    # Use explicit 'install' field if present, else build default command
    install_cmd = info.get("install") or f"{mgr} install -g {pkg}"
    on_path = shutil.which(name) is not None
    mgr_available = managers.get(mgr) is not None

    status = "ok" if on_path else "missing"
    marker = "✓" if on_path else "✗"
    print(f"  {marker} {name}  [{mgr}]  [{status}]")
    if desc:
        print(f"    {desc}")
    if not on_path:
        if mgr_available:
            print(f"    Install: {install_cmd}")
        else:
            print(f"    Install: (install {mgr} first, then: {install_cmd})")
PYEOF

echo ""
