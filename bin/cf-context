#!/usr/bin/env bash
# cf-context — fingerprint the current project and write a compact summary
#
# Usage:
#   cf-context          # print to stdout
#   cf-context --write  # also write to .claudefiles/context.md

set -euo pipefail

CF_LIB="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)/../lib"
source "$CF_LIB/common.sh"

WRITE=false
for arg in "$@"; do [[ "$arg" == "--write" ]] && WRITE=true; done

GIT_ROOT="$(cf_git_root)"
OUT=""
line() { OUT+="$*"$'\n'; }
blank() { OUT+=$'\n'; }

NOW="$(date '+%Y-%m-%d %H:%M:%S')"
line "# PROJECT CONTEXT"
line "# Generated: $NOW"
line "# Root: $GIT_ROOT"
blank

LANGS=()
[[ -f "$GIT_ROOT/package.json" ]]        && LANGS+=("Node.js")
[[ -f "$GIT_ROOT/bun.lock" || -f "$GIT_ROOT/bun.lockb" ]] && LANGS+=("Bun")
[[ -f "$GIT_ROOT/Cargo.toml" ]]          && LANGS+=("Rust")
[[ -f "$GIT_ROOT/go.mod" ]]              && LANGS+=("Go")
[[ -f "$GIT_ROOT/pyproject.toml" || -f "$GIT_ROOT/requirements.txt" ]] && LANGS+=("Python")
[[ -f "$GIT_ROOT/Gemfile" ]]             && LANGS+=("Ruby")
[[ -f "$GIT_ROOT/pom.xml" || -f "$GIT_ROOT/build.gradle" ]] && LANGS+=("Java/JVM")
[[ -f "$GIT_ROOT/composer.json" ]]       && LANGS+=("PHP")

line "RUNTIME"
if [[ ${#LANGS[@]} -gt 0 ]]; then
    line "  languages:    $(IFS=', '; echo "${LANGS[*]}")"
else
    line "  languages:    unknown"
fi

PKG_MGR="none"
[[ -f "$GIT_ROOT/bun.lockb" || -f "$GIT_ROOT/bun.lock" ]] && PKG_MGR="bun"
[[ -f "$GIT_ROOT/pnpm-lock.yaml" ]]  && PKG_MGR="pnpm"
[[ -f "$GIT_ROOT/yarn.lock" ]]       && PKG_MGR="yarn"
[[ -f "$GIT_ROOT/package-lock.json" && "$PKG_MGR" == "none" ]] && PKG_MGR="npm"
[[ -f "$GIT_ROOT/Cargo.lock" ]]      && PKG_MGR="cargo"
[[ -f "$GIT_ROOT/go.sum" ]]          && PKG_MGR="go mod"
[[ -f "$GIT_ROOT/uv.lock" ]]         && PKG_MGR="uv"
[[ -f "$GIT_ROOT/poetry.lock" ]]     && PKG_MGR="poetry"
line "  package mgr:  $PKG_MGR"

FRAMEWORKS=()
if [[ -f "$GIT_ROOT/package.json" ]]; then
    PKG="$(cat "$GIT_ROOT/package.json")"
    echo "$PKG" | grep -q '"next"'    && FRAMEWORKS+=("Next.js")
    echo "$PKG" | grep -q '"react"'   && FRAMEWORKS+=("React")
    echo "$PKG" | grep -q '"vue"'     && FRAMEWORKS+=("Vue")
    echo "$PKG" | grep -q '"svelte"'  && FRAMEWORKS+=("Svelte")
    echo "$PKG" | grep -q '"express"' && FRAMEWORKS+=("Express")
    echo "$PKG" | grep -q '"fastify"' && FRAMEWORKS+=("Fastify")
    echo "$PKG" | grep -q '"hono"'    && FRAMEWORKS+=("Hono")
    echo "$PKG" | grep -q '"astro"'   && FRAMEWORKS+=("Astro")
fi
if [[ -f "$GIT_ROOT/Cargo.toml" ]]; then
    grep -q 'axum'   "$GIT_ROOT/Cargo.toml" && FRAMEWORKS+=("Axum")
    grep -q 'actix'  "$GIT_ROOT/Cargo.toml" && FRAMEWORKS+=("Actix")
    grep -q 'rocket' "$GIT_ROOT/Cargo.toml" && FRAMEWORKS+=("Rocket")
fi
if [[ -f "$GIT_ROOT/pyproject.toml" ]]; then
    grep -q 'fastapi' "$GIT_ROOT/pyproject.toml" && FRAMEWORKS+=("FastAPI")
    grep -q 'django'  "$GIT_ROOT/pyproject.toml" && FRAMEWORKS+=("Django")
    grep -q 'flask'   "$GIT_ROOT/pyproject.toml" && FRAMEWORKS+=("Flask")
fi
[[ ${#FRAMEWORKS[@]} -gt 0 ]] && line "  frameworks:   $(IFS=', '; echo "${FRAMEWORKS[*]}")"
blank

BRANCH="$(git -C "$GIT_ROOT" symbolic-ref --short HEAD 2>/dev/null || echo "detached")"
DIRTY="$(git -C "$GIT_ROOT" status --short 2>/dev/null | wc -l | tr -d ' ')"
COMMITS_AHEAD="$(git -C "$GIT_ROOT" rev-list --count '@{upstream}..HEAD' 2>/dev/null || echo 0)"

line "GIT"
line "  branch:       $BRANCH"
line "  uncommitted:  $DIRTY file(s)"
[[ "$COMMITS_AHEAD" -gt 0 ]] && line "  unpushed:     $COMMITS_AHEAD commit(s)"

if cf_bus_exists; then
    BUS_FILES="$(ls "$(cf_bus)" 2>/dev/null | tr '\n' ' ')"
    line "  .claudefiles: $BUS_FILES"
fi
blank

line "KEY FILES"
for f in README.md CLAUDE.md .env .env.example tsconfig.json Makefile Dockerfile docker-compose.yml; do
    [[ -f "$GIT_ROOT/$f" ]] && line "  $f"
done
blank

printf '%s' "$OUT"

if "$WRITE"; then
    BUS="$(cf_ensure_bus)"
    printf '%s' "$OUT" > "$BUS/context.md"
    echo "# Written to $BUS/context.md" >&2
fi
