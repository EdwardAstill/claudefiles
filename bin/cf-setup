#!/usr/bin/env bash
# cf-setup — check tool dependencies for the skills installed in this project
#
# Reads .claude/skills/ to discover which skills are active, then looks up
# their declared tool and CLI requirements in manifest.toml. Reports what is
# installed, what is missing, and writes a summary to .claudefiles/deps.md.
#
# Usage:
#   cf-setup           # check deps for all locally installed skills
#   cf-setup --write   # also write .claudefiles/deps.md
#   cf-setup --skills "git-expert,docs-agent"  # check specific skills by name

set -euo pipefail

CF_LIB="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)/../lib"
source "$CF_LIB/common.sh"

WRITE=false
EXPLICIT_SKILLS=""

for arg in "$@"; do
    case "$arg" in
        --write)   WRITE=true ;;
        --skills)  shift; EXPLICIT_SKILLS="$1" ;;
    esac
done

# ── Locate manifest.toml ──────────────────────────────────────────────────────
# Prefer the home claudefiles install, fall back to the repo this script is in.

MANIFEST=""
for candidate in \
    "$HOME/.claudefiles/manifest.toml" \
    "$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)/../manifest.toml"
do
    [[ -f "$candidate" ]] && MANIFEST="$candidate" && break
done

if [[ -z "$MANIFEST" ]]; then
    echo "Error: manifest.toml not found. Is claudefiles installed to ~/.claudefiles/?" >&2
    exit 1
fi

# ── Discover installed skills ─────────────────────────────────────────────────

GIT_ROOT="$(cf_git_root 2>/dev/null || echo "")"
PROJECT_SKILLS_DIR="${GIT_ROOT:+$GIT_ROOT/.claude/skills}"

if [[ -n "$EXPLICIT_SKILLS" ]]; then
    INSTALLED_SKILLS="$(echo "$EXPLICIT_SKILLS" | tr ',' '\n' | tr -d ' ')"
elif [[ -n "$PROJECT_SKILLS_DIR" && -d "$PROJECT_SKILLS_DIR" ]]; then
    # Read skill names from SKILL.md files under .claude/skills/
    INSTALLED_SKILLS=""
    while IFS= read -r skill_md; do
        name="$(awk '/^name:/ { gsub(/^name: */, ""); print; exit }' "$skill_md" 2>/dev/null)"
        [[ -n "$name" ]] && INSTALLED_SKILLS+="$name"$'\n'
    done < <(find "$PROJECT_SKILLS_DIR" -name "SKILL.md" 2>/dev/null)
else
    echo "No project skills found. Run this inside a project with skills installed."
    echo "Install skills with: cf-setup --skills \"git-expert,docs-agent\""
    exit 0
fi

if [[ -z "$INSTALLED_SKILLS" ]]; then
    echo "No skills found in $PROJECT_SKILLS_DIR"
    exit 0
fi

# ── Run the dependency check ──────────────────────────────────────────────────

OUTPUT="$(
set -euo pipefail

# ── Parse manifest.toml ───────────────────────────────────────────────────────
declare -A sk_tools=() sk_mcp=() sk_cli=()
declare -A cl_mgr=() cl_pkg=() cl_desc=() cl_install=()

_sec="" _key=""
while IFS= read -r _ln; do
    [[ -z "$_ln" || "$_ln" == \#* ]] && continue
    if   [[ "$_ln" =~ ^\[skills\.([^]]+)\]$ ]]; then
        _sec=skills; _key="${BASH_REMATCH[1]}"
        sk_tools[$_key]=""; sk_mcp[$_key]=""; sk_cli[$_key]=""
    elif [[ "$_ln" =~ ^\[cli\.([^]]+)\]$ ]]; then
        _sec=cli; _key="${BASH_REMATCH[1]}"
        cl_mgr[$_key]=""; cl_pkg[$_key]=""; cl_desc[$_key]=""; cl_install[$_key]=""
    elif [[ "$_ln" =~ ^\[ ]]; then
        _sec=""; _key=""
    elif [[ "$_sec" == skills && -n "$_key" ]]; then
        # Parse TOML array → space-separated values
        _v="$(sed 's/^[^=]*= *\[//; s/\].*//; s/"//g; s/,  */ /g' <<< "$_ln")"
        case "$_ln" in
            tools*)  sk_tools[$_key]="$_v" ;;
            mcp*)    sk_mcp[$_key]="$_v"   ;;
            cli*)    sk_cli[$_key]="$_v"   ;;
        esac
    elif [[ "$_sec" == cli && -n "$_key" ]]; then
        if   [[ "$_ln" =~ ^manager[[:space:]]*=[[:space:]]*\"([^\"]+)\" ]];     then cl_mgr[$_key]="${BASH_REMATCH[1]}"
        elif [[ "$_ln" =~ ^package[[:space:]]*=[[:space:]]*\"([^\"]+)\" ]];     then cl_pkg[$_key]="${BASH_REMATCH[1]}"
        elif [[ "$_ln" =~ ^description[[:space:]]*=[[:space:]]*\"([^\"]+)\" ]]; then cl_desc[$_key]="${BASH_REMATCH[1]}"
        elif [[ "$_ln" =~ ^install[[:space:]]*=[[:space:]]*\"([^\"]+)\" ]];     then cl_install[$_key]="${BASH_REMATCH[1]}"
        fi
    fi
done < "$MANIFEST"

declare -A MGR_INSTALL=(
    [bun]="curl -fsSL https://bun.sh/install | bash"
    [uv]="curl -LsSf https://astral.sh/uv/install.sh | sh"
    [cargo]="curl https://sh.rustup.rs -sSf | sh"
    [rustup]="curl https://sh.rustup.rs -sSf | sh"
)

# ── Generate skill sections ───────────────────────────────────────────────────
_tmp_body="$(mktemp)"
_tmp_pm="$(mktemp)"
trap 'rm -f "$_tmp_body" "$_tmp_pm"' EXIT

ANY_MISSING=false
USED_MGRS=""

while IFS= read -r skill_name; do
    [[ -z "$skill_name" ]] && continue
    [[ -z "${sk_tools[$skill_name]+set}" ]] && continue   # not in manifest

    echo "## ${skill_name}" >> "$_tmp_body"

    _tools="${sk_tools[$skill_name]}"
    [[ -n "$_tools" ]] && echo "  Claude tools : ${_tools// /, }" >> "$_tmp_body"

    _mcp="${sk_mcp[$skill_name]}"
    [[ -n "$_mcp" ]] && echo "  MCP servers  : ${_mcp// /, }" >> "$_tmp_body"

    _cli="${sk_cli[$skill_name]}"
    if [[ -n "$_cli" ]]; then
        for cli_name in $_cli; do
            mgr="${cl_mgr[$cli_name]:-?}"
            pkg="${cl_pkg[$cli_name]:-$cli_name}"
            desc="${cl_desc[$cli_name]:-}"
            inst="${cl_install[$cli_name]:-}"
            [[ -z "$inst" ]] && inst="${mgr} install -g ${pkg}"
            USED_MGRS="$USED_MGRS $mgr"

            if command -v "$cli_name" &>/dev/null; then
                echo "  ✓  ${cli_name}  [${mgr}]  installed" >> "$_tmp_body"
            else
                ANY_MISSING=true
                echo "  ✗  ${cli_name}  [${mgr}]  MISSING" >> "$_tmp_body"
                [[ -n "$desc" ]] && echo "       ${desc}" >> "$_tmp_body"
                if command -v "$mgr" &>/dev/null; then
                    echo "       Install: ${inst}" >> "$_tmp_body"
                else
                    echo "       Install ${mgr} first (${MGR_INSTALL[$mgr]:-?}), then: ${inst}" >> "$_tmp_body"
                fi
            fi
        done
    fi
    echo "" >> "$_tmp_body"
done < <(echo "$INSTALLED_SKILLS" | sort)

# ── Package manager summary — only managers actually needed ───────────────────
for mgr in bun uv cargo rustup; do
    echo " $USED_MGRS " | grep -qF " $mgr " || continue
    if _p="$(command -v "$mgr" 2>/dev/null)"; then
        echo "  ✓  ${mgr}   ${_p}" >> "$_tmp_pm"
    else
        ANY_MISSING=true
        echo "  ✗  ${mgr}   not installed" >> "$_tmp_pm"
        echo "       ${MGR_INSTALL[$mgr]:-}" >> "$_tmp_pm"
    fi
done

# ── Assemble final output ─────────────────────────────────────────────────────
echo "# Project Skill Dependencies"
echo ""
if [[ -s "$_tmp_pm" ]]; then
    echo "## Package managers"
    cat "$_tmp_pm"
    echo ""
fi
cat "$_tmp_body"
$ANY_MISSING || echo "All dependencies satisfied."
)"

echo "$OUTPUT"

if "$WRITE"; then
    BUS="$(cf_ensure_bus)"
    echo "$OUTPUT" > "$BUS/deps.md"
    echo ""
    echo "  Written to $BUS/deps.md"
fi
