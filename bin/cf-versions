#!/usr/bin/env bash
# cf-versions — read installed dependency versions from the current project
#
# Usage:
#   cf-versions           # print to stdout
#   cf-versions --write   # also write to .claudefiles/versions.md

set -euo pipefail

CF_LIB="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)/../lib"
source "$CF_LIB/common.sh"

WRITE=false
for arg in "$@"; do [[ "$arg" == "--write" ]] && WRITE=true; done

GIT_ROOT="$(cf_git_root)"
OUT=""
line() { OUT+="$*"$'\n'; }
blank() { OUT+=$'\n'; }
header() { line "$1"; line "$(printf '%0.s─' $(seq 1 ${#1}))"; }

NOW="$(date '+%Y-%m-%d %H:%M:%S')"
line "# DEPENDENCY VERSIONS"
line "# Generated: $NOW"
line "# Root: $GIT_ROOT"
blank

FOUND=false

if [[ -f "$GIT_ROOT/package.json" ]]; then
    FOUND=true
    header "package.json"
    blank
    if command -v node &>/dev/null; then
        node -e "
const p = require('$GIT_ROOT/package.json');
const all = { ...p.dependencies, ...p.devDependencies, ...p.peerDependencies };
Object.entries(all).sort().forEach(([k,v]) => console.log('  ' + k.padEnd(40) + v));
" 2>/dev/null || true
    else
        awk '
            /"dependencies"|"devDependencies"|"peerDependencies"/ { in_block=1 }
            in_block && /"[^"]+": "[^"]+"/ { gsub(/[",]/, ""); gsub(/^ +/, "  "); print }
            in_block && /^\s*\}/ { in_block=0 }
        ' "$GIT_ROOT/package.json"
    fi
    blank
fi

if [[ -f "$GIT_ROOT/Cargo.toml" ]]; then
    FOUND=true
    header "Cargo.toml"
    blank
    if [[ -f "$GIT_ROOT/Cargo.lock" ]]; then
        awk '
            /^\[\[package\]\]/ { name=""; version="" }
            /^name = / { name=gensub(/"/, "", "g", $3) }
            /^version = / { version=gensub(/"/, "", "g", $3); if (name) printf "  %-40s %s\n", name, version }
        ' "$GIT_ROOT/Cargo.lock" | sort
    else
        awk '
            /^\[dependencies\]|^\[dev-dependencies\]|^\[build-dependencies\]/ { in_block=1; next }
            /^\[/ { in_block=0 }
            in_block && /=/ { print "  " $0 }
        ' "$GIT_ROOT/Cargo.toml"
    fi
    blank
fi

if [[ -f "$GIT_ROOT/go.mod" ]]; then
    FOUND=true
    header "go.mod"
    blank
    awk '/^require/,/^\)/ { if ($0 !~ /^require|^\)/) printf "  %-50s %s\n", $1, $2 }' "$GIT_ROOT/go.mod" | sort
    blank
fi

if [[ -f "$GIT_ROOT/pyproject.toml" ]]; then
    FOUND=true
    header "pyproject.toml"
    blank
    if [[ -f "$GIT_ROOT/uv.lock" ]]; then
        awk '
            /^\[\[package\]\]/ { name=""; version="" }
            /^name = / { name=gensub(/"/, "", "g", $3) }
            /^version = / { version=gensub(/"/, "", "g", $3); if (name) printf "  %-40s %s\n", name, version }
        ' "$GIT_ROOT/uv.lock" | sort
    elif [[ -f "$GIT_ROOT/poetry.lock" ]]; then
        awk '
            /^\[\[package\]\]/ { name=""; version="" }
            /^name = / { name=gensub(/"/, "", "g", $3) }
            /^version = / { version=gensub(/"/, "", "g", $3); if (name) printf "  %-40s %s\n", name, version }
        ' "$GIT_ROOT/poetry.lock" | sort
    else
        awk '
            /^\[project\]/ { in_proj=1 }
            /^\[/ && !/^\[project\]/ { in_proj=0 }
            in_proj && /dependencies/ { in_deps=1 }
            in_deps && /\]/ { in_deps=0 }
            in_deps && /"/ { gsub(/[",\[\]]/, ""); gsub(/^ +/, "  "); print }
        ' "$GIT_ROOT/pyproject.toml"
    fi
    blank
fi

if [[ -f "$GIT_ROOT/requirements.txt" && ! -f "$GIT_ROOT/pyproject.toml" ]]; then
    FOUND=true
    header "requirements.txt"
    blank
    grep -v '^\s*#' "$GIT_ROOT/requirements.txt" | grep -v '^\s*$' | sed 's/^/  /'
    blank
fi

if ! "$FOUND"; then
    line "No recognised dependency files found."
    blank
fi

printf '%s' "$OUT"

if "$WRITE"; then
    BUS="$(cf_ensure_bus)"
    printf '%s' "$OUT" > "$BUS/versions.md"
    echo "# Written to $BUS/versions.md" >&2
fi
