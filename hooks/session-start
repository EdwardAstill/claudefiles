#!/usr/bin/env bash
# SessionStart hook — injects using-agentfiles into every Claude Code session

set -euo pipefail

PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "$0")/.." && pwd)}"

# Search paths in preference order. First match wins.
CANDIDATES=(
    "$PLUGIN_ROOT/agentfiles/management/meta/using-agentfiles/SKILL.md"
    "$PLUGIN_ROOT/skills/management/meta/using-agentfiles/SKILL.md"
    "$HOME/.claude/skills/using-agentfiles/SKILL.md"
)

SKILL_FILE=""
for candidate in "${CANDIDATES[@]}"; do
    if [[ -f "$candidate" ]]; then
        SKILL_FILE="$candidate"
        break
    fi
done

if [[ -z "$SKILL_FILE" ]]; then
    exit 0
fi

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

content=$(cat "$SKILL_FILE")
content_escaped=$(escape_for_json "$content")

# If anomalies from recent sessions are unreviewed (file exists, non-empty), flag them.
ANOMALIES_FILE="$HOME/.claude/logs/anomalies.md"
anomaly_note=""
if [[ -s "$ANOMALIES_FILE" ]]; then
    count=$(grep -c '^## ' "$ANOMALIES_FILE" 2>/dev/null || echo 0)
    anomaly_note="\n\n**Routing anomalies from recent sessions:** ${count} session(s) had self-loops, deep chains, or wasted skill loads. Review with \`af log review\` or clear with \`rm ${ANOMALIES_FILE}\`."
fi

# Pre-run `af context` + `af status` so the session starts with project state
# already loaded (deterministic enforcement of the orient step). Silently skip
# if `af` isn't on PATH or the commands fail — we still inject the skill body.
orient_block=""
if command -v af >/dev/null 2>&1; then
    af_context=$(af context 2>/dev/null || true)
    af_status=$(af status 2>/dev/null || true)
    if [[ -n "$af_context" || -n "$af_status" ]]; then
        orient_raw=$'\n\n---\n**Project state at session start (via `af context` + `af status`):**\n\n```\n'"$af_context"$'\n\n'"$af_status"$'\n```\n'
        orient_block=$(escape_for_json "$orient_raw")
    fi
fi

context="<EXTREMELY_IMPORTANT>\nYou must invoke using-agentfiles before starting any task.\n\n**Below is the full content of your 'using-agentfiles' skill:**\n\n${content_escaped}${orient_block}${anomaly_note}\n</EXTREMELY_IMPORTANT>"

printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$context"

exit 0
